pipeline {
    agent any
    tools {
        maven "Maven"
    }
    environment {
        DOCKERHUB_PWD = credentials('CredentialID_DockerHubPWD')
    }
    stages {
        stage('Checkout') {
            steps {
                git branch: 'master', url: 'https://github.com/Aziz2534Cen/comp367app-.git'
            }
        }
        stage('Build') {
            steps {
                dir('eclipse-workspace25/comp367app') {
                    bat 'mvn clean package'
                }
            }
        }
        stage('Unit Test') {
            steps {
                dir('eclipse-workspace25/comp367app') {
                    bat 'mvn test'
                }
            }
        }
        stage('Docker build') {
            steps {
                script {
                    dir('eclipse-workspace25/comp367app') {
                        bat 'docker build -t aziz2534/comp367app:1.0 .'
                    }
                }
            }
        }
        stage('Docker login') {
            steps {
                script {
                    bat "docker login -u aziz2534 -p ${DOCKERHUB_PWD}"
                }
            }
        }
        stage('Docker push') {
            steps {
                script {
                    bat 'docker push aziz2534/comp367app:1.0'
                }
            }
        }
        stage('Deploy to Dev') {
            steps {
                script {
                    bat 'docker run -d -p 9092:8080 aziz2534/comp367app:1.0'
                }
            }
        }
        stage('Deploy to QAT') {
            steps {
                script {
                    bat 'echo Deploying to QAT environment'
                }
            }
        }
        stage('Deploy to Staging') {
            steps {
                script {
                    bat 'echo Deploying to Staging environment'
                }
            }
        }
        stage('Deploy to Production') {
            steps {
                script {
                    bat 'echo Deploying to Production environment'
                }
            }
        }
    }
}
